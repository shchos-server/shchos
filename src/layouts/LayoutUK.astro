---
import LocaleSwitcher from "../components/LocaleSwitcher.astro";
import JoinServer from "../components/JoinServer.astro";

import '../css/reset.css'
import 'normalize.css/normalize.css'

const title = Astro.props.title ?? "Щось";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:opsz,wght@17..18,400..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <a href="/uk">
        <h2>щось</h2>
      </a>
      <nav>
        <ul>
          <li><a href="/uk/rules">Rules</a></li>
          <li><a href="/uk/sosem">Sosem</a></li>
        </ul>
      </nav>
        <LocaleSwitcher />
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  * {
    font-family: "Google Sans", sans-serif;
  }
</style>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    background-color: #2c2d32;
    color: #fff;

    a {
      color: #fff;
    }
  }

  header {
    display: flex;
    padding: 10px 50px;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #393a3f;
  }

  nav {
    display: none;
  }

  @media screen and (min-width: 420px) {
    nav {
      display: block;
    }
  }

  h2 {
    font-family: "Google Sans", sans-serif;
    font-size: 28px;
    color: #fff;
  }

  a {
    text-decoration: none;
  }

  ul {
    display: flex;
    gap: 50px;
    list-style: none;
  }
</style>
