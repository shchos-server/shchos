---
import LocaleSwitcher from "../components/LocaleSwitcher.astro";
import JoinServer from "../components/JoinServer.astro";

import "../css/reset.css";
import "normalize.css/normalize.css";

const title = Astro.props.title ?? "щось";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Official website for Discord server щось (shchos)" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#5865f2" />

    <meta property="og:title" content={title === "щось" ? `щось` : `${title} - щось`} />
    <meta
      property="og:description"
      content="Official website for Discord server щось (shchos)"
    />
    <meta property="og:url" content="https://shchos-server.github.io/en" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:locale:alternate" content="uk_UA" />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:opsz,wght@17..18,400..700&display=swap"
      rel="stylesheet"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href="/en">
        <h2>щось</h2>
      </a>
      <nav>
        <ul>
          <li><a href="/en/rules">Rules</a></li>
          <li><a href="/en/sosem">Sosem</a></li>
        </ul>
      </nav>
      <LocaleSwitcher />
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  * {
    font-family: "Google Sans", sans-serif;
  }
</style>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    background-color: #2c2d32;
    color: #fff;

    a {
      color: #fff;
    }
  }

  header {
    display: flex;
    padding: 10px 50px;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #393a3f;
  }

  nav {
    display: none;
  }

  @media screen and (min-width: 420px) {
    nav {
      display: block;
    }
  }

  h2 {
    font-size: 28px;
    color: #fff;
  }

  a {
    text-decoration: none;
  }

  ul {
    display: flex;
    gap: 50px;
    list-style: none;
  }
</style>
