---
const label =
  Astro.currentLocale === "uk"
    ? "ДО ПОЧАТКУ СЕРВЕРА"
    : "TO THE START OF THE SERVER";

const joinBefore =
  Astro.currentLocale === "uk"
    ? "Спробуйте зайти до того як таймер закінчится"
    : "Try joining before timer runs out";

const timerDone = 
  Astro.currentLocale === "uk"
    ? "СЕРВЕР АКТИВНИЙ ПРЯМО ЗАРАЗ!"
    : "IT'S ON RIGHT NOW"   
---

<h2>{label}</h2>
<div id="countdown">
  <div>
    <span class="unit days">99d</span>
    <span class="unit hours">99h</span>
  </div>
  <div>
    <span class="unit minutes">99m</span>
    <span class="unit seconds">99s</span>
  </div>
</div>
<p>{joinBefore}</p>

<script define:vars={{ timerDone }} is:inline>
  const target = new Date("2026-06-27T14:08:00+01:00").getTime();

  const countdown = document.querySelector("#countdown");
  const days = document.querySelector(".days");
  const hours = document.querySelector(".hours");
  const minutes = document.querySelector(".minutes");
  const seconds = document.querySelector(".seconds");

  function tick() {
    const diff = target - Date.now();
    if (diff <= 0) {
      countdown.innerHTML = `<h1 style="color: #0f0">${timerDone}</h1>`;
      return;
    }

    days.textContent = `${Math.floor(diff / 86400000)}d`;
    hours.textContent = `${Math.floor(diff / 3600000) % 24}h`;
    minutes.textContent = `${Math.floor(diff / 60000) % 60}m`;
    seconds.textContent = `${Math.floor(diff / 1000) % 60}s`;
  }

  tick();
  setInterval(tick, 1000);
</script>

<style>
  h2 {
    text-align: center;
    margin-bottom: 10px;
  }

  #countdown {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin: 10px 0;

    div {
      display: flex;
      gap: 10px;
    }
  }

  .unit {
    display: flex;
    width: 90px;
    height: 120px;
    justify-content: center;
    align-items: center;
    font-size: 36px;
    border: 3px solid #fff;
    border-radius: 25px;
    color: #fff;
  }
</style>
