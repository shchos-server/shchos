---
const { fontSize = '16px' } = Astro.props;

const label =
  Astro.currentLocale === "uk" ? "Приєднатися до сервера" : "Join server";
---

<a href="/inv"><button type="button">{label}</button></a>

<style define:vars={{ fontSize }}>
  button {
    padding: 1em;
    border: none;
    font-size: var(--fontSize);
    text-wrap: nowrap;
    border-radius: 1.5em;
    background-color: #5865f2;
    color: #fff;
  }
</style>
