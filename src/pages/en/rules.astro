---
import Layout from "../../layouts/LayoutEN.astro";
import { getEntry, render } from "astro:content";

const locale = Astro.currentLocale ?? "en";
const rules = await getEntry("rules", locale);

if (!rules) throw new Error(`No rules entry found for locale: ${locale}`);

const { Content } = await render(rules);

const pageTitle = rules.data.title;
---

<Layout title={pageTitle}>
  <article class="content">
    <Content />
  </article>
</Layout>

<style is:global>
  .content {
    max-width: 726px;
    padding: 0 10px;
    margin: 0 auto;
  }

  img {
    display: block;
    margin: 0 auto;
  }

  img[src*="/logo.gif"] {
    height: auto;
    max-width: 420px;
    width: 100%;
  }

  blockquote {
    font-style: italic;
    font-weight: 400;
    color: #ffffff7b;
    text-align: center;
  }
</style>
