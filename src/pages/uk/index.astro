---
import Layout from "../../layouts/LayoutUK.astro";
import JoinServer from "../../components/JoinServer.astro";
import Card from "../../components/Card.astro";
---

<Layout>
  <div class="content">
    <h2>Вітаємо на <span class="title">щось</span></h2>
    <JoinServer fontSize="24px" />
    <div class="cards">
      <Card title="Правила" desc="(Або Конституция сервера щось) це обов'язкові правила серверу які має прочитати кожен." href="/uk/rules" />
      <Card title="Sosem 3" desc="3 сезон Майнкрафт серверу Sosem та вся інформація про сервер та як зайти." href="/uk/sosem" />
    </div>
  </div>
</Layout>

<style>
  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 1080px;
    padding: 50px 0;
    margin: 0 auto;
  }

  h2 {
    font-size: 36px;
    margin-bottom: 30px;
  }

  .title {
    color: #5865f2;
  }

  .cards {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 50px;
    margin-top: 80px;
  }
</style>
