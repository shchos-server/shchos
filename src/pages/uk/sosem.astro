---
import { Image } from "astro:assets";

import Layout from "../../layouts/LayoutUK.astro";
import Card from "../../components/Card.astro";

import Copy from "../../assets/copy.svg";
---

<Layout>
  <div class="content">
    <div class="join-info">
      <div class="join-java">
        <h3>Java</h3>
        <div class="join-field">
          <p>sosem3.bestmc.fun</p>
          <button type="button" value="sosem3.bestmc.fun">
            <Copy />
          </button>
        </div>
      </div>
      <div class="join-bedrock">
        <h3>Bedrock</h3>
        <div class="join-field">
          <p>sosem3server</p>
          <button type="button" value="sosem3server">
            <Copy />
          </button>
        </div>
        <p>
          Додайте цей <b>нік до ваших Xbox друзів</b> та потім приєднайтесь до світу
          щоб грати!
        </p>
      </div>
    </div>
    <h3>Версія серверу: 26.2+</h3>
    <div class="cards">
      <Card title="Без спідрану">
        <p>Наприклад отримати фулл незерітову броню за перший день серверу</p>
        <p>
          <b>P.s</b> Незер буде відкритий через тиждень після початку сервера
        </p>
      </Card>
      <Card title="Ділитесь знахідками">
        <p>
          Ділитися знайденими речами, особливо якщо вони вам не потрібні, пам'ятайте що вони можуть бути потрібні іншим
        </p>
      </Card>
      <Card title="Тримайтесь разом">
        <p>
          Жити группою разом наприклад в містечку, <b
            >бажаний радіус 100 блоків</b
          >
        </p>
      </Card>
      <Card title="Не гріферіть">
        <p>Не гріферіть дома інших гравців та не будьте "злодієм"</p>
      </Card>
      <Card title="ПАМ'ЯТАЙТЕ!">
        <p>
          Чіти які <b
            >дают переваги над іншими гравцями (X-ray, Auto-Mining, тощо.) та/або
            впливають на роботу сервера заборонено</b
          >
        </p>
      </Card>
    </div>
    <div class="plugins">
      <div class="bluemap">
        <div class="info">
          <Image
            src="/bluemap.png"
            alt="Bluemap Logo"
            width="100"
            height="100"
            style={{ borderRadius: "50px" }}
          />
          <h2>Bluemap</h2>
          <p>Жива мапа серверу</p>
        </div>
        <a href="http://srv76.godlike.club:26370/" target="_blank"
          ><button type="button">Перейти</button></a
        >
      </div>
      <div class="simplevoice">
        <div class="info">
          <Image
            src="/simplevoice.png"
            alt="Simple Voice Chat Logo"
            width="100"
            height="100"
          />
          <h2>Simple Voice Chat</h2>
          <p>Проксіміті-чат (тільки на Java Edition!)</p>
        </div>
        <a href="https://modrinth.com/plugin/simple-voice-chat" target="_blank"
          ><button type="button">Завантажити</button></a
        >
      </div>
    </div>
  </div>
</Layout>

<style>
  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 100vw;
    padding: 30px 0;
    margin: 0 auto;
  }

  .join-info {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    margin: 50px 0;
    gap: 50px;
  }

  h3 {
    font-size: 28px;
    text-align: center;
    color: #fff;
    margin: 0;
  }

  .join-field {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 56px;
    width: 260px;
    margin: 28px 0;
    border: 3px solid #ffffff7b;
    border-radius: 10px;
    color: #ffffff7b;
  }

  button {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 56px;
    height: 56px;
    background-color: transparent;
    border: none;
    border-left: 2px solid #ffffff7b;
  }

  svg {
    width: 32px;
    height: 32px;
    fill: #ffffff7b;
  }

  p {
    max-width: 200px;
    margin: 0 auto;
    font-size: 18px;
    color: #ffffff7b;
    text-align: center;
  }

  .cards {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 50px;
    margin: 50px 0;
  }

  .plugins {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 1fr;
    gap: 50px;
    max-width: 1216px;
    height: 350px;
    padding: 0 25px;
  }

  @media (max-width: 768px) {
    .plugins {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      height: auto;
    }
  }
  .bluemap,
  .simplevoice {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 50px;
    padding: 30px;
    border: 2px solid #ffffff7b;
    border-radius: 20px;
    text-align: center;

    a {
      width: 100%;
    }

    button {
      width: 100%;
      height: 50px;
      background-color: #5865f2;
      border: none;
      border-radius: 20px;
      color: #fff;
    }
  }

  .bluemap {
    background: transparent;
    background: linear-gradient(
      174deg,
      rgba(0, 4, 39, 0) 0%,
      rgba(6, 23, 144, 1) 100%
    );
  }

  .simplevoice {
    background: transparent;
    background: linear-gradient(
      174deg,
      rgba(0, 4, 39, 0) 0%,
      rgba(209, 209, 209, 1) 100%
    );
  }
</style>

<script>
  const joinInfo = document.querySelector(".join-info");

  joinInfo?.addEventListener("click", (e) => {
    const target = e.target as Element;
    const button = target?.closest("button");
    if (!button) {
      return;
    }

    navigator.clipboard.writeText(button.value);
  });
</script>
