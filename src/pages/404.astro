    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 1080px;
    padding: 50px 0;
    margin: 0 auto;
    text-align: center;
  }

  a {
    color: #5865f2;
    text-decoration: underline;
  }
</style>
